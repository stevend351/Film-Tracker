# Postgres — Railway provides this automatically when you attach the Postgres plugin.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Session signing key. 32+ random bytes. Generate locally:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-long-random-string

# Initial passwords for seeded users. Change these the first time the app boots,
# or via a future password-reset flow. If unset, server logs a warning and
# generates random passwords (printed once to logs).
INITIAL_ADMIN_PW=change-me-steven
INITIAL_KITCHEN_PW=change-me-brenda

# Optional. Set to 1 to skip the boot-time seed (e.g. for migrations-only runs).
# SKIP_SEED=0

# Railway sets PORT automatically. Defaults to 5000 locally.
# PORT=5000

# Set NODE_ENV=production in Railway. Locally, npm run dev sets development.
# NODE_ENV=production
